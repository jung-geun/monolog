# Notion Configuration (REQUIRED)
# Get these values from your Notion workspace

# Required: Notion Integration Token
# Get your token at: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx

# Required: Notion DataSource ID (with hyphens)
# This is the database ID in UUID format
NOTION_DATASOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Analytics (Optional)
NEXT_PUBLIC_GOOGLE_MEASUREMENT_ID=

# Google Search Console (Optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Naver Search Advisor (Optional)
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# Notion Comments (Optional — enable in site.config.js notionComments.enable)
# The DB ID of a Notion database shared with your integration (see README for schema)
NOTION_COMMENTS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Salt for IP/nickname hashing — generate with: openssl rand -hex 32
COMMENT_HASH_SALT=
# Number of trusted reverse-proxy hops in front of Next.js (default: 0 = ignore X-Forwarded-For)
# Set to 1 if behind a single load balancer / Nginx proxy
TRUSTED_PROXY_HOPS=0

# Utterances Comments (Optional)
NEXT_PUBLIC_UTTERANCES_REPO=
